{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AgentPhone",
  "colors": {
    "primary": "#10B981",
    "light": "#34D399",
    "dark": "#059669"
  },
  "favicon": "/favicon.svg",
  "css": "/custom.css",
  "background": {
    "style": "gradient"
  },
  "font": {
    "headings": { "family": "Outfit" },
    "body": { "family": "DM Sans" }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "api-reference/quickstart",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "api-reference/agents",
              "api-reference/numbers",
              "api-reference/calls",
              "api-reference/conversations",
              "api-reference/webhooks"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "api-reference/pagination",
              "api-reference/error-handling",
              "api-reference/limits-quotas"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "api-reference/code-examples",
              "api-reference/best-practices",
              "api-reference/testing"
            ]
          },
          {
            "group": "FAQ",
            "pages": [
              "api-reference/faq"
            ]
          }
        ]
      },
      {
        "tab": "AI Tools",
        "groups": [
          {
            "group": "MCP Integrations",
            "pages": [
              "ai-tools/claude-code",
              "ai-tools/cursor",
              "ai-tools/windsurf"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/AgentPhone-AI",
          "icon": "github"
        },
        {
          "anchor": "Dashboard",
          "href": "https://agentphone.to",
          "icon": "gauge"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/logo.png",
    "dark": "/logo/logo.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@agentphone.to"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://agentphone.to"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/AgentPhone-AI"
    }
  }
}
